    "url": "https://github.com/raychiikk/TradeSim/issues"
  },
  "homepage": "https://github.com/raychiikk/TradeSim#readme",
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@vitest/ui": "^4.1.4",
    "c8": "^11.0.0",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
