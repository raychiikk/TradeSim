{
  "name": "tradesim",
  "version": "1.0.0",
  "description": "**TradeSim** — це високопродуктивна система для розробки, тестування та аналізу алгоритмічних торгових стратегій на історичних ринкових даних.",
  "main": "index.js",
  "type": "module",
"scripts": {
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx src/index.ts",
    "docs": "typedoc --entryPointStrategy expand ./src --out docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raychiikk/TradeSim.git"
  },
